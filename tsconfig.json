{
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"strict": true,
		"useDefineForClassFields": false,
		"experimentalDecorators": true,
		"lib": ["ESNext", "DOM"],
		"outDir": "./lib/",
		"rootDir": "./src/",
		"types": ["chrome", "youtube"],
		"skipLibCheck": true
	},
	"include": ["./src/**/*"],
	"exclude": ["./node_modules"]
}
