{
	"name": "youtube-xbox",
	"version": "0.1.0",
	"description": "",
	"type": "module",
	"scripts": {
		"build": "wireit",
		"build:ts": "wireit",
		"build:rollup": "wireit"
	},
	"devDependencies": {
		"@types/chrome": "^0.2.2",
		"@types/youtube": "^0.3.0",
		"@vdegenne/bip": "^1.0.4",
		"@vdegenne/debouncer": "^1.0.17",
		"@vdegenne/mini-gamepad": "^0.4.16",
		"@vdegenne/py-server": "^0.1.7",
		"@vdegenne/rollup": "^0.1.18",
		"@vdegenne/youtube": "^0.1.20",
		"@vite-pwa/assets-generator": "^1.0.2",
		"html-vision": "^0.3.10",
		"typescript": "^7.0.2",
		"wireit": "^0.14.13"
	},
	"wireit": {
		"bip": {
			"command": "bip",
			"dependencies": [
				"build:rollup"
			]
		},
		"build": {
			"dependencies": [
				"build:ts",
				"build:rollup",
				"pwa-assets",
				"bip"
			]
		},
		"build:ts": {
			"command": "tsc",
			"clean": "if-file-deleted",
			"files": [
				"./tsconfig.json",
				"./src/"
			],
			"output": [
				"./lib/"
			]
		},
		"build:rollup": {
			"command": "rollup -c",
			"dependencies": [
				"build:ts"
			],
			"files": [
				"./tsconfig.json",
				"./lib/",
				"./rollup.config.js"
			],
			"output": [
				"./content.js",
				"./background.js"
			]
		},
		"pwa-assets": {
			"command": "pwa-assets-generator --preset minimal-2023 --html.preset 2023 ./assets/images/logo.svg",
			"files": [
				"./assets/images/logo.svg"
			],
			"output": [
				"./assets/images/pwa-64x64.png",
				"./assets/images/pwa-192x192.png",
				"./assets/images/pwa-512x512.png",
				"./assets/images/maskable-icon-512x512.png",
				"./assets/images/apple-touch-icon-180x180.png",
				"./assets/images/favicon.ico"
			]
		}
	}
}
